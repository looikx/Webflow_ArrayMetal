"<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #fff; color: #1a1a1a; line-height: 1.5; }\n  .page { max-width: 900px; margin: 0 auto; padding: 3rem 1.5rem 4rem; }\n\n  /* \u2500\u2500 Hero \u2500\u2500 */\n  .hero { margin-bottom: 2.5rem; }\n  .hero-label { font-size: 11px; font-weight: 500; letter-spacing: 0.8px; text-transform: uppercase; color: #aaa; margin-bottom: 0.75rem; }\n  .hero h1 { font-size: 28px; font-weight: 600; color: #1a1a1a; margin-bottom: 0.75rem; line-height: 1.25; }\n  .hero p { font-size: 14px; color: #555; max-width: 600px; line-height: 1.7; }\n\n  /* \u2500\u2500 Standard badges \u2500\u2500 */\n  .standards { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 1.25rem; }\n  .std-badge { font-size: 11px; font-weight: 500; padding: 4px 10px; border-radius: 6px; background: #f0f0ee; color: #444; border: 0.5px solid #ddd; }\n  .std-badge.green { background: #eaf3de; color: #3b6d11; border-color: #c3dfa0; }\n  .std-badge.blue  { background: #e6f1fb; color: #185FA5; border-color: #b3d4f0; }\n\n  /* \u2500\u2500 Test conditions section \u2500\u2500 */\n  .test-conditions { margin-bottom: 2.5rem; }\n  .test-conditions-title { font-size: 13px; font-weight: 600; color: #1a1a1a; margin-bottom: 1rem; letter-spacing: 0.1px; }\n  .test-conditions-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }\n  .tc-card { border: 0.5px solid #e0e0e0; border-radius: 10px; padding: 1.25rem; background: #fff; }\n  .tc-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 0.5px solid #f0f0f0; }\n  .tc-card-name { font-size: 14px; font-weight: 600; color: #1a1a1a; }\n  .tc-card-scope { font-size: 11px; color: #aaa; margin-top: 2px; }\n  .tc-row { display: flex; justify-content: space-between; align-items: baseline; padding: 5px 0; border-bottom: 0.5px solid #f5f5f5; font-size: 12px; }\n  .tc-row:last-child { border-bottom: none; }\n  .tc-key { color: #666; }\n  .tc-val { color: #1a1a1a; font-weight: 500; text-align: right; max-width: 55%; }\n  .sf-highlight { display: inline-block; background: #eaf3de; color: #3b6d11; font-weight: 600; font-size: 12px; padding: 2px 8px; border-radius: 5px; }\n  .sf-highlight.blue { background: #e6f1fb; color: #185FA5; }\n\n  /* \u2500\u2500 Series block \u2500\u2500 */\n  .series-block { margin-bottom: 2.5rem; }\n  .series-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 0.5px solid #e0e0e0; }\n  .series-title { font-size: 16px; font-weight: 600; color: #1a1a1a; }\n  .series-meta { font-size: 12px; color: #888; margin-top: 2px; }\n  .series-badges { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }\n\n  /* \u2500\u2500 SWL table \u2500\u2500 */\n  .table-wrap { overflow-x: auto; border: 0.5px solid #e0e0e0; border-radius: 10px; }\n  .swl-table { width: 100%; border-collapse: collapse; font-size: 13px; }\n  .swl-table thead tr { border-bottom: 1px solid #e0e0e0; }\n  .swl-table th { padding: 8px 12px; text-align: left; font-size: 11px; font-weight: 500; color: #888; letter-spacing: 0.4px; white-space: nowrap; }\n  .swl-table th.num { text-align: right; }\n  .swl-table th.span-col { background: #fafaf8; text-align: right; }\n  .swl-table tbody tr { border-bottom: 0.5px solid #f0f0f0; transition: background 0.1s; }\n  .swl-table tbody tr:last-child { border-bottom: none; }\n  .swl-table tbody tr:hover { background: #fafaf8; }\n  .swl-table td { padding: 10px 12px; vertical-align: middle; }\n  .swl-table td.model { font-weight: 600; color: #1a1a1a; font-size: 13px; }\n  .swl-table td.num { text-align: right; color: #1a1a1a; font-variant-numeric: tabular-nums; }\n  .swl-table td.dim { color: #666; font-size: 12px; }\n  .swl-table td.span-col { background: #fafaf8; text-align: right; font-variant-numeric: tabular-nums; }\n\n  .nema-pill { display: inline-block; font-size: 11px; font-weight: 500; padding: 2px 8px; border-radius: 6px; }\n  .nema-20aa { background: #fff3dc; color: #7a4f00; }\n  .nema-20a  { background: #fdecea; color: #8b1a1a; }\n  .nema-20b  { background: #eaf3de; color: #3b6d11; }\n\n  /* \u2500\u2500 Note box \u2500\u2500 */\n  .note { display: flex; gap: 10px; align-items: flex-start; padding: 12px 14px; background: #e6f1fb; border-radius: 8px; margin-top: 0.75rem; }\n  .note span { font-size: 12px; color: #185FA5; line-height: 1.6; }\n\n  /* \u2500\u2500 Section divider \u2500\u2500 */\n  .section-divider { border: none; border-top: 0.5px solid #e8e8e8; margin: 2.5rem 0; }\n\n  /* \u2500\u2500 Footer note \u2500\u2500 */\n  .footer-note { margin-top: 3rem; padding-top: 1.5rem; border-top: 0.5px solid #e0e0e0; display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem; }\n  .footer-note p { font-size: 12px; color: #888; line-height: 1.7; }\n  .footer-note a { color: #185FA5; text-decoration: none; }\n  .footer-note a:hover { text-decoration: underline; }\n\n  /* \u2500\u2500 Back link \u2500\u2500 */\n  .back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: #555; text-decoration: none; margin-bottom: 2rem; }\n  .back-link:hover { color: #1a1a1a; }\n  .back-link svg { width: 14px; height: 14px; }\n\n  @media (max-width: 640px) {\n    .page { padding: 2rem 1rem 3rem; }\n    .hero h1 { font-size: 22px; }\n    .series-header { flex-direction: column; align-items: flex-start; }\n    .test-conditions-grid { grid-template-columns: 1fr; }\n  }\n\n  @media print {\n    body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n    .page { padding: 1rem; }\n    .back-link { display: none; }\n  }\n</style>\n<div class=\"page\">\n\n  <a href=\"/products/cable-ladder\" class=\"back-link\">\n    <svg viewBox=\"0 0 16 16\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><path d=\"M10 3L5 8l5 5\"/></svg>\n    Cable Ladder\n  </a>\n\n  <!-- \u2550\u2550 Hero \u2550\u2550 -->\n  <div class=\"hero\">\n    <div class=\"hero-label\">Array Metal (M) Sdn. Bhd.</div>\n    <h1>Cable Ladder Load Ratings</h1>\n    <p>Safe Working Load (SWL) values for all tested cable ladder series. All values are single-span results with the applicable safety factor applied. Test conditions and safety factors are detailed at the bottom of this page.</p>\n    <div class=\"standards\">\n      <span class=\"std-badge green\">IEC 61537</span>\n      <span class=\"std-badge green\">NEMA VE1-2009</span>\n      <span class=\"std-badge blue\">SIRIM Tested</span>\n      <span class=\"std-badge\">HDG \u00b7 ISO 1461</span>\n    </div>\n  </div>\n\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n       AML Series\n  \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <div class=\"series-block\">\n    <div class=\"series-header\">\n      <div>\n        <div class=\"series-title\">AML Series \u2014 Cable Ladder</div>\n        <div class=\"series-meta\">Material: Hot-Dip Galvanized (HDG) &nbsp;\u00b7&nbsp; Standard: NEMA VE1-2009 &nbsp;\u00b7&nbsp; Safety factor: \u00d71.5</div>\n      </div>\n      <div class=\"series-badges\">\n        <span class=\"std-badge green\">NEMA VE1-2009</span>\n        <span class=\"std-badge\">HDG</span>\n      </div>\n    </div>\n    <div class=\"table-wrap\">\n      <table class=\"swl-table\">\n        <thead>\n          <tr>\n            <th>Model</th>\n            <th>Loading Depth</th>\n            <th>Thickness</th>\n            <th class=\"span-col\">SWL @ 3 m <span style=\"font-weight:400;color:#bbb\">(kg/m)</span></th>\n            <th class=\"span-col\">SWL @ 4.5 m <span style=\"font-weight:400;color:#bbb\">(kg/m)</span></th>\n            <th class=\"span-col\">SWL @ 6 m <span style=\"font-weight:400;color:#bbb\">(kg/m)</span></th>\n            <th>NEMA Class</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td class=\"model\">AML100</td>\n            <td class=\"dim\">75 mm</td>\n            <td class=\"dim\">1.5 / 2 mm</td>\n            <td class=\"span-col\">192</td>\n            <td class=\"span-col\">85</td>\n            <td class=\"span-col\">48</td>\n            <td><span class=\"nema-pill nema-20aa\">NEMA 20AA</span></td>\n          </tr>\n          <tr>\n            <td class=\"model\">AML125</td>\n            <td class=\"dim\">100 mm</td>\n            <td class=\"dim\">1.5 / 2 mm</td>\n            <td class=\"span-col\">480</td>\n            <td class=\"span-col\">213</td>\n            <td class=\"span-col\">120</td>\n            <td><span class=\"nema-pill nema-20b\">NEMA 20B</span></td>\n          </tr>\n          <tr>\n            <td class=\"model\">AML150</td>\n            <td class=\"dim\">125 mm</td>\n            <td class=\"dim\">1.5 / 2 mm</td>\n            <td class=\"span-col\">468</td>\n            <td class=\"span-col\">208</td>\n            <td class=\"span-col\">117</td>\n            <td><span class=\"nema-pill nema-20b\">NEMA 20B</span></td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n    <div class=\"note\">\n      <span>SWL = Destructive load \u00f7 1.5 (NEMA VE1-2009). Available lengths: 3 m and 6 m. Deflection limit: L/100 at SWL.</span>\n    </div>\n  </div>\n\n  <hr class=\"section-divider\">\n\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n       APO Series\n  \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <div class=\"series-block\">\n    <div class=\"series-header\">\n      <div>\n        <div class=\"series-title\">APO Series \u2014 Cable Ladder</div>\n        <div class=\"series-meta\">Material: Hot-Dip Galvanized (HDG) &nbsp;\u00b7&nbsp; Standard: SIRIM / NEMA VE1-2009 &nbsp;\u00b7&nbsp; Safety factor: \u00d71.5</div>\n      </div>\n      <div class=\"series-badges\">\n        <span class=\"std-badge green\">SIRIM Certified</span>\n        <span class=\"std-badge green\">NEMA VE1-2009</span>\n        <span class=\"std-badge\">HDG</span>\n      </div>\n    </div>\n    <div class=\"table-wrap\">\n      <table class=\"swl-table\">\n        <thead>\n          <tr>\n            <th>Model</th>\n            <th>Loading Depth</th>\n            <th>Thickness</th>\n            <th class=\"span-col\">SWL @ 3 m <span style=\"font-weight:400;color:#bbb\">(kg/m)</span></th>\n            <th class=\"span-col\">SWL @ 4.5 m <span style=\"font-weight:400;color:#bbb\">(kg/m)</span></th>\n            <th class=\"span-col\">SWL @ 6 m <span style=\"font-weight:400;color:#bbb\">(kg/m)</span></th>\n            <th>NEMA Class</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td class=\"model\">APO100</td>\n            <td class=\"dim\">75 mm</td>\n            <td class=\"dim\">1.5 / 2 mm</td>\n            <td class=\"span-col\">192</td>\n            <td class=\"span-col\">85</td>\n            <td class=\"span-col\">48</td>\n            <td><span class=\"nema-pill nema-20aa\">NEMA 20AA</span></td>\n          </tr>\n          <tr>\n            <td class=\"model\">APO125</td>\n            <td class=\"dim\">100 mm</td>\n            <td class=\"dim\">1.5 / 2 mm</td>\n            <td class=\"span-col\">416</td>\n            <td class=\"span-col\">185</td>\n            <td class=\"span-col\">104</td>\n            <td><span class=\"nema-pill nema-20a\">NEMA 20A</span></td>\n          </tr>\n          <tr>\n            <td class=\"model\">APO150</td>\n            <td class=\"dim\">125 mm</td>\n            <td class=\"dim\">1.5 / 2 mm</td>\n            <td class=\"span-col\">540</td>\n            <td class=\"span-col\">240</td>\n            <td class=\"span-col\">135</td>\n            <td><span class=\"nema-pill nema-20b\">NEMA 20B</span></td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n    <div class=\"note\">\n      <span>SWL = Destructive load \u00f7 1.5 (NEMA VE1-2009). Test certificate reference: SIRIM-NEMA VE1-2009. Available lengths: 3 m and 6 m.</span>\n    </div>\n  </div>\n\n  <hr class=\"section-divider\">\n\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n       ACD Series\n  \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <div class=\"series-block\">\n    <div class=\"series-header\">\n      <div>\n        <div class=\"series-title\">ACD Series \u2014 Cable Ladder</div>\n        <div class=\"series-meta\">Material: Hot-Dip Galvanized (HDG) &nbsp;\u00b7&nbsp; Standard: IEC 61537:2006 &nbsp;\u00b7&nbsp; Safety factor: \u00d71.7</div>\n      </div>\n      <div class=\"series-badges\">\n        <span class=\"std-badge green\">IEC 61537 Tested</span>\n        <span class=\"std-badge\">HDG</span>\n      </div>\n    </div>\n    <div class=\"table-wrap\">\n      <table class=\"swl-table\">\n        <thead>\n          <tr>\n            <th>Model</th>\n            <th>Loading Depth</th>\n            <th>Thickness</th>\n            <th class=\"span-col\">SWL @ 3 m <span style=\"font-weight:400;color:#bbb\">(kg/m)</span></th>\n            <th class=\"span-col\">SWL @ 4.5 m <span style=\"font-weight:400;color:#bbb\">(kg/m)</span></th>\n            <th class=\"span-col\">SWL @ 6 m <span style=\"font-weight:400;color:#bbb\">(kg/m)</span></th>\n            <th>NEMA Class</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td class=\"model\">ACD100</td>\n            <td class=\"dim\">75 mm</td>\n            <td class=\"dim\">1.5 mm <span style=\"color:#aaa;font-size:11px\">(tested)</span></td>\n            <td class=\"span-col\">239</td>\n            <td class=\"span-col\">106</td>\n            <td class=\"span-col\">60</td>\n            <td><span class=\"nema-pill nema-20aa\">NEMA 20AA</span></td>\n          </tr>\n          <tr>\n            <td class=\"model\">ACD125</td>\n            <td class=\"dim\">100 mm</td>\n            <td class=\"dim\">1.5 / 2 mm</td>\n            <td class=\"span-col\">560</td>\n            <td class=\"span-col\">249</td>\n            <td class=\"span-col\">140</td>\n            <td><span class=\"nema-pill nema-20b\">NEMA 20B</span></td>\n          </tr>\n          <tr>\n            <td class=\"model\">ACD150</td>\n            <td class=\"dim\">125 mm</td>\n            <td class=\"dim\">1.5 / 2 mm</td>\n            <td class=\"span-col\">579</td>\n            <td class=\"span-col\">257</td>\n            <td class=\"span-col\">145</td>\n            <td><span class=\"nema-pill nema-20b\">NEMA 20B</span></td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n    <div class=\"note\">\n      <span>SWL = Breaking load \u00f7 1.7 (IEC 61537:2006). Breaking load confirmed \u2265 1.7 \u00d7 SWL by test. Certificate ref: 2018MA0594-ACD-IEC61537. Available lengths: 3 m and 6 m. Full test certificate available on request.</span>\n    </div>\n  </div>\n\n  <hr class=\"section-divider\">\n\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n       ART / AMT Series\n  \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <div class=\"series-block\">\n    <div class=\"series-header\">\n      <div>\n        <div class=\"series-title\">ART / AMT Series \u2014 Cable Tray</div>\n        <div class=\"series-meta\">Material: Hot-Dip Galvanized (HDG) &nbsp;\u00b7&nbsp; Standard: NEMA VE1-2009 &nbsp;\u00b7&nbsp; Safety factor: \u00d71.5</div>\n      </div>\n      <div class=\"series-badges\">\n        <span class=\"std-badge green\">NEMA VE1-2009</span>\n        <span class=\"std-badge\">HDG</span>\n      </div>\n    </div>\n    <div class=\"table-wrap\">\n      <table class=\"swl-table\">\n        <thead>\n          <tr>\n            <th>Model</th>\n            <th>Loading Depth</th>\n            <th>Thickness</th>\n            <th class=\"span-col\">SWL @ 1.5 m <span style=\"font-weight:400;color:#bbb\">(kg/m)</span></th>\n            <th class=\"span-col\">SWL @ 2 m <span style=\"font-weight:400;color:#bbb\">(kg/m)</span></th>\n            <th class=\"span-col\">SWL @ 3 m <span style=\"font-weight:400;color:#bbb\">(kg/m)</span></th>\n            <th>NEMA Class</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td class=\"model\">ART50</td>\n            <td class=\"dim\">50 mm</td>\n            <td class=\"dim\">1.5 / 2 mm</td>\n            <td class=\"span-col\">484</td>\n            <td class=\"span-col\">272</td>\n            <td class=\"span-col\">121</td>\n            <td><span class=\"nema-pill nema-20aa\">NEMA 20AA</span></td>\n          </tr>\n          <tr>\n            <td class=\"model\">AMT100</td>\n            <td class=\"dim\">100 mm</td>\n            <td class=\"dim\">1.5 / 2 mm</td>\n            <td class=\"span-col\">716</td>\n            <td class=\"span-col\">403</td>\n            <td class=\"span-col\">179</td>\n            <td><span class=\"nema-pill nema-20b\">NEMA 20B</span></td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n    <div class=\"note\">\n      <span>SWL = Destructive load \u00f7 1.5 (NEMA VE1-2009). Available lengths: 3 m and 6 m. Deflection limit: L/100 at SWL.</span>\n    </div>\n  </div>\n\n  <hr class=\"section-divider\">\n\n  <!-- \u2550\u2550 Test Conditions \u2550\u2550 -->\n  <div class=\"test-conditions\">\n    <div class=\"test-conditions-title\">Test conditions &amp; safety factors</div>\n    <div class=\"test-conditions-grid\">\n\n      <div class=\"tc-card\">\n        <div class=\"tc-card-header\">\n          <div>\n            <div class=\"tc-card-name\">NEMA VE1-2009</div>\n            <div class=\"tc-card-scope\">APO \u00b7 AML \u00b7 ART \u00b7 AMT series</div>\n          </div>\n          <span class=\"std-badge green\">NEMA</span>\n        </div>\n        <div class=\"tc-row\"><span class=\"tc-key\">Test type</span><span class=\"tc-val\">Single-span, uniformly distributed load</span></div>\n        <div class=\"tc-row\"><span class=\"tc-key\">Safety factor</span><span class=\"tc-val\"><span class=\"sf-highlight\">\u00d71.5</span></span></div>\n        <div class=\"tc-row\"><span class=\"tc-key\">SWL definition</span><span class=\"tc-val\">Destructive load \u00f7 1.5</span></div>\n        <div class=\"tc-row\"><span class=\"tc-key\">Deflection limit</span><span class=\"tc-val\">L/100 at SWL</span></div>\n        <div class=\"tc-row\"><span class=\"tc-key\">Load classification</span><span class=\"tc-val\">20AA, 20A, 20B (increasing capacity)</span></div>\n        <div class=\"tc-row\"><span class=\"tc-key\">Test body</span><span class=\"tc-val\">SIRIM (Malaysia)</span></div>\n      </div>\n\n      <div class=\"tc-card\">\n        <div class=\"tc-card-header\">\n          <div>\n            <div class=\"tc-card-name\">IEC 61537:2006</div>\n            <div class=\"tc-card-scope\">ACD series</div>\n          </div>\n          <span class=\"std-badge green\">IEC</span>\n        </div>\n        <div class=\"tc-row\"><span class=\"tc-key\">Test type</span><span class=\"tc-val\">Single-span, uniformly distributed load</span></div>\n        <div class=\"tc-row\"><span class=\"tc-key\">Safety factor</span><span class=\"tc-val\"><span class=\"sf-highlight\">\u00d71.7</span></span></div>\n        <div class=\"tc-row\"><span class=\"tc-key\">SWL definition</span><span class=\"tc-val\">Breaking load \u00f7 1.7</span></div>\n        <div class=\"tc-row\"><span class=\"tc-key\">Deflection limit</span><span class=\"tc-val\">L/100 at SWL</span></div>\n        <div class=\"tc-row\"><span class=\"tc-key\">Breaking load</span><span class=\"tc-val\">Confirmed \u2265 1.7 \u00d7 SWL by test</span></div>\n        <div class=\"tc-row\"><span class=\"tc-key\">Certificate ref</span><span class=\"tc-val\">2018MA0594-ACD-IEC61537</span></div>\n      </div>\n\n    </div>\n  </div>\n\n  <!-- \u2550\u2550 Footer \u2550\u2550 -->\n  <div class=\"footer-note\">\n    <p>\n      All SWL values are safe working loads with safety factors applied per the respective test standard.<br>\n      Loading depth refers to the internal usable cable fill depth of the ladder side rail.<br>\n      NEMA classification per NEMA VE1-2009: 20AA &lt; 20A &lt; 20B (increasing load capacity).\n    </p>\n    <p style=\"text-align:right;\">\n      For test certificates, material traceability<br>\n      or vendor prequalification documents \u2014<br>\n      <a href=\"/contact-us\">contact our engineering team</a>\n    </p>\n  </div>\n\n</div>"
